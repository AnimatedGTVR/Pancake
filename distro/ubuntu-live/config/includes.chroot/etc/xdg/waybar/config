{
    "layer": "top",
    "position": "bottom",
    "height": 44,
    "margin-bottom": 8,
    "margin-left": 16,
    "margin-right": 16,
    "spacing": 0,
    "exclusive": true,

    "modules-left": [
        "custom/start",
        "custom/sep",
        "custom/ws1",
        "custom/ws2",
        "custom/ws3",
        "custom/ws4",
        "custom/ws5"
    ],

    "modules-center": [
        "clock"
    ],

    "modules-right": [
        "cpu",
        "memory",
        "pulseaudio",
        "network",
        "battery",
        "tray"
    ],

    "custom/start": {
        "format": "🥞",
        "tooltip": "Super+D  open apps\nSuper+Enter  terminal",
        "on-click": "wofi --show drun"
    },

    "custom/sep": {
        "format": "|",
        "tooltip": false
    },

    "custom/ws1": { "format": "1", "tooltip": false },
    "custom/ws2": { "format": "2", "tooltip": false },
    "custom/ws3": { "format": "3", "tooltip": false },
    "custom/ws4": { "format": "4", "tooltip": false },
    "custom/ws5": { "format": "5", "tooltip": false },

    "clock": {
        "format": "  {:%H:%M}",
        "format-alt": "  {:%a %d %b %Y}",
        "tooltip-format": "<tt>{calendar}</tt>"
    },

    "cpu": {
        "format": " {usage}%",
        "interval": 3,
        "tooltip": false
    },

    "memory": {
        "format": " {used:0.1f}G",
        "tooltip": false
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": " ",
        "format-icons": { "default": ["", "", ""] },
        "on-click": "pamixer -t",
        "tooltip": false
    },

    "network": {
        "format-wifi": " {signalStrength}%",
        "format-ethernet": " eth",
        "format-disconnected": " off",
        "tooltip-format": "{ifname}: {ipaddr}\n{essid}",
        "interval": 5
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-charging": " {capacity}%",
        "format-icons": ["", "", "", "", ""],
        "states": { "warning": 30, "critical": 15 },
        "tooltip": false
    },

    "tray": {
        "icon-size": 16,
        "spacing": 6
    }
}
