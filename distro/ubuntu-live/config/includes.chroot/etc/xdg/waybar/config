{
    "layer": "top",
    "position": "bottom",
    "height": 44,
    "margin-bottom": 10,
    "margin-left": 12,
    "margin-right": 12,
    "spacing": 0,
    "exclusive": true,

    "modules-left": [
        "custom/start",
        "custom/ws1",
        "custom/ws2",
        "custom/ws3",
        "custom/ws4",
        "custom/ws5"
    ],

    "modules-center": [
        "clock"
    ],

    "modules-right": [
        "cpu",
        "memory",
        "pulseaudio",
        "network",
        "battery",
        "tray"
    ],

    "custom/start": {
        "format": "🥞",
        "tooltip": "Super+D  open apps\nSuper+Enter  terminal\nSuper+Q  close window",
        "on-click": "wofi --show drun"
    },

    "custom/ws1": { "format": "⬤", "tooltip": "Workspace 1", "on-click": "" },
    "custom/ws2": { "format": "⬤", "tooltip": "Workspace 2", "on-click": "" },
    "custom/ws3": { "format": "⬤", "tooltip": "Workspace 3", "on-click": "" },
    "custom/ws4": { "format": "⬤", "tooltip": "Workspace 4", "on-click": "" },
    "custom/ws5": { "format": "⬤", "tooltip": "Workspace 5", "on-click": "" },

    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%a %d %b}",
        "tooltip-format": "<tt>{calendar}</tt>"
    },

    "cpu": {
        "format": "⬡ {usage}%",
        "interval": 3,
        "tooltip": false
    },

    "memory": {
        "format": "▪ {used:0.1f}G",
        "tooltip": false
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "✕",
        "format-icons": { "default": ["▁", "▄", "█"] },
        "on-click": "pamixer -t",
        "tooltip": false
    },

    "network": {
        "format-wifi": "  {signalStrength}%",
        "format-ethernet": "⬡ eth",
        "format-disconnected": "✕",
        "tooltip-format": "{ifname}: {ipaddr}\n{essid}",
        "interval": 5
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-charging": "⚡ {capacity}%",
        "format-icons": ["▁", "▂", "▄", "▆", "█"],
        "states": { "warning": 30, "critical": 15 },
        "tooltip": false
    },

    "tray": {
        "icon-size": 15,
        "spacing": 5
    }
}
