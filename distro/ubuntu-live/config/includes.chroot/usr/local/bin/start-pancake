#!/usr/bin/env bash
set -euo pipefail

export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/0}"
export LIBSEAT_BACKEND="${LIBSEAT_BACKEND:-seatd}"

# Theming
export GTK_THEME=Breeze-Dark
export XCURSOR_THEME=Breeze_Snow
export XCURSOR_SIZE=24
export QT_QPA_PLATFORMTHEME=gtk3
export QT_AUTO_SCREEN_SCALE_FACTOR=1

mkdir -p "$XDG_RUNTIME_DIR"
chmod 700 "$XDG_RUNTIME_DIR"

# ── Deploy default configs on first boot ─────────────────────────────────────
HYPR_CFG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/hypr"
mkdir -p "$HYPR_CFG_DIR"

# Pancake's Hyprland config
if [ ! -f "$HYPR_CFG_DIR/hyprland.conf" ] && [ -f /etc/hypr/hyprland.conf ]; then
    cp /etc/hypr/hyprland.conf "$HYPR_CFG_DIR/hyprland.conf"
fi

# Waybar config (copy to user config only if not already customised)
WAYBAR_CFG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/waybar"
if [ ! -d "$WAYBAR_CFG_DIR" ]; then
    mkdir -p "$WAYBAR_CFG_DIR"
    [ -f /etc/xdg/waybar/config ]    && cp /etc/xdg/waybar/config    "$WAYBAR_CFG_DIR/config"
    [ -f /etc/xdg/waybar/style.css ] && cp /etc/xdg/waybar/style.css "$WAYBAR_CFG_DIR/style.css"
fi

# Wofi config
WOFI_CFG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/wofi"
if [ ! -d "$WOFI_CFG_DIR" ]; then
    mkdir -p "$WOFI_CFG_DIR"
    [ -f /etc/xdg/wofi/config ]     && cp /etc/xdg/wofi/config     "$WOFI_CFG_DIR/config"
    [ -f /etc/xdg/wofi/style.css ]  && cp /etc/xdg/wofi/style.css  "$WOFI_CFG_DIR/style.css"
fi

# Foot terminal config
FOOT_CFG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/foot"
if [ ! -f "$FOOT_CFG_DIR/foot.ini" ]; then
    mkdir -p "$FOOT_CFG_DIR"
    [ -f /etc/xdg/foot/foot.ini ] && cp /etc/xdg/foot/foot.ini "$FOOT_CFG_DIR/foot.ini"
fi

# XDG user directories
xdg-user-dirs-update 2>/dev/null || true

# ── Start seat daemon ─────────────────────────────────────────────────────────
if command -v systemctl >/dev/null 2>&1; then
    systemctl is-active --quiet seatd.service 2>/dev/null \
        || systemctl start seatd.service 2>/dev/null \
        || true
fi

# ── Launch Hyprland ────────────────────────────────────────────────────────────
# Hyprland's own exec-once directives (in hyprland.conf) now own launching
# swaybg/dunst/waybar/nm-applet/pipewire — there is no socket-poll or manual
# component sequencing here anymore, unlike the old compositor's launcher.
printf 'Starting Pancake (Hyprland)...\n'
exec Hyprland
